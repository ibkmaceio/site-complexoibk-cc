# Copie este arquivo para .env.local e preencha os valores
# Nunca comite o .env.local no git

# Google Analytics (Fase 2)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Formulário de contato — Web3Forms (https://web3forms.com)
# NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key

# CMS — Sanity (Fase 2)
# NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
